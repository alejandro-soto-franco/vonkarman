# =============================================================================
# vonkarman .gitignore — high-precision numerical simulation
# =============================================================================

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
/target/
**/*.d
**/*.o
**/*.so
**/*.dylib
**/*.a
**/*.lib
**/*.dll
**/*.exe

# ---------------------------------------------------------------------------
# Superpowers / local docs (never publish plans or specs to GitHub)
# ---------------------------------------------------------------------------
docs/

# ---------------------------------------------------------------------------
# Simulation output (large, machine-specific)
# ---------------------------------------------------------------------------
output/
runs/
sweeps/
*.h5
*.hdf5
*.parquet
*.arrow
*.checkpoint
*.checkpoint.tmp
*.bin
manifest.json
manifest.json.tmp
run.log

# ---------------------------------------------------------------------------
# CUDA / GPU build artifacts
# ---------------------------------------------------------------------------
*.ptx
*.cubin
*.fatbin
*.gpu
*.i
*.ii
*.cu.o
**/*.cu.deps

# ---------------------------------------------------------------------------
# VkFFT build artifacts
# ---------------------------------------------------------------------------
vkfft_build/
*.spv

# ---------------------------------------------------------------------------
# FFTW wisdom files (machine-specific, regenerated at runtime)
# ---------------------------------------------------------------------------
*.wisdom
fftw_wisdom*

# ---------------------------------------------------------------------------
# High-precision intermediate data
# ---------------------------------------------------------------------------
*.mpfr
*.qd
*.dd
*.highprec

# ---------------------------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ---------------------------------------------------------------------------
# Profiling / benchmarks
# ---------------------------------------------------------------------------
flamegraph.svg
perf.data
perf.data.old
*.prof
criterion/
cachegrind.out.*
callgrind.out.*

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
*.secret
*.key
*.pem

# ---------------------------------------------------------------------------
# OS artifacts
# ---------------------------------------------------------------------------
Thumbs.db
Desktop.ini
._*

# ---------------------------------------------------------------------------
# Temporary files
# ---------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
*.rej
tmp/
temp/

# ---------------------------------------------------------------------------
# Coverage / test artifacts
# ---------------------------------------------------------------------------
*.gcda
*.gcno
*.gcov
tarpaulin-report.html
lcov.info
coverage/

# ---------------------------------------------------------------------------
# Package manager
# ---------------------------------------------------------------------------
Cargo.lock
# Cargo.lock is excluded for libraries (workspace of libs).
# If vonkarman-bin becomes the primary consumer, move this to .gitignore exceptions.

# ---------------------------------------------------------------------------
# Core dumps
# ---------------------------------------------------------------------------
core
core.*
vgcore.*
